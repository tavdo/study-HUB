# Optional: OpenAI key for smarter answers (uses your live Study Hub data in the prompt).
# Without it, the built-in assistant still answers Study Hub + study questions.
REACT_APP_OPENAI_API_KEY=
REACT_APP_OPENAI_MODEL=gpt-4o-mini

# Optional: local free AI via Ollama (recommended locally only).
# Railway/production: set to false (Ollama does not run on Railway).
REACT_APP_USE_LOCAL_AI=true

# Production API URL — leave empty when API and UI share one domain (Railway single service).
# Separate frontend host: REACT_APP_API_URL=https://your-api.up.railway.app
REACT_APP_API_URL=
