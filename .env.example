# Optional: OpenAI key for smarter answers (uses your live Study Hub data in the prompt).
# Without it, the built-in assistant still answers Study Hub + study questions.
REACT_APP_OPENAI_API_KEY=
REACT_APP_OPENAI_MODEL=gpt-4o-mini

# Optional: local free AI via Ollama (recommended).
# Run `npm run server` and make sure Ollama is running locally.
REACT_APP_USE_LOCAL_AI=true
