PORT=5050
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
JWT_SECRET=change-me-to-a-long-random-string

# ამ ელფოსტის მქონე მომხმარებელი ავტომატურად გახდება ადმინი (ცარიელი = პირველი რეგისტრაცია)
ADMIN_EMAIL=

# Docker: npm run db:up  → შემდეგ ეს URL:
DATABASE_URL="postgresql://studyhub:studyhub_dev@localhost:5432/studyhub_db"

# ხელით დაყენებული PostgreSQL-ისთვის შეცვალე user/password/db:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/studyhub_db"
